# Backend env vars — copy to .env and fill in
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/elliot_ai
JWT_SECRET=change-me-in-prod
JWT_ALGO=HS256
JWT_EXPIRE_MIN=60

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# OAuth 2.0 — shared framework for all connectors
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8000
FERNET_KEY=

# SSO
OKTA_DOMAIN=
ENTRA_TENANT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_WORKSPACE_DOMAIN=elliotsystems.com
