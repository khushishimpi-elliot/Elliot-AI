# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/elliot_ai

# ── AI APIs ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-
OPENAI_API_KEY=sk-

# ── Email (Resend) ────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=onboarding@resend.dev

# ── JWT & Auth ────────────────────────────────────────
JWT_SECRET=your-long-random-secret-here
JWT_ALGO=HS256
JWT_EXPIRE_MIN=60

# ── App URLs (change for production) ──────────────────
BACKEND_URL=http://localhost:8000
TERMINAL_URL=http://localhost:5173
DASHBOARD_URL=http://localhost:5174
OAUTH_REDIRECT_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Magic Link ────────────────────────────────────────
MAGIC_LINK_BASE_URL=http://localhost:5173/auth/callback

# ── Google OAuth ──────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_WORKSPACE_DOMAIN=

# ── Microsoft Entra OAuth ─────────────────────────────
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# ── Auth0 SSO ─────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_CALLBACK_URL=http://localhost:8000/auth/auth0/callback
AUTH0_AUDIENCE=

# ── GitHub Connector ──────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# ── GitLab Connector ──────────────────────────────────
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# ── Bitbucket Connector ───────────────────────────────
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=

# ── Jira Connector ────────────────────────────────────
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# ── Linear Connector ──────────────────────────────────
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# ── Slack Connector ───────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ── ClickUp Connector ─────────────────────────────────
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=

# ── Security ──────────────────────────────────────────
FERNET_KEY=your-32-byte-base64-encoded-key

# ── Environment ───────────────────────────────────────
APP_ENV=development
